# Generated by `devg init-env` from your host environment.
# Copy this to .env and fill in values, or let devg init-env do it automatically.
#
# These are passed to the proxy sidecar for MCP server auth.
# The app container never sees them.

# GitHub token (for MCP servers that need GitHub access)
# GH_TOKEN=ghp_...

# Context7 API key (free from context7.com/dashboard)
# CONTEXT7_API_KEY=...
